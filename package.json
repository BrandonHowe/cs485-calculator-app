{
  "name": "calculator-app",
  "version": "1.0.0",
  "private": true,
  "description": "Basic calculator app with React frontend and Node.js backend",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run server",
    "server": "PORT=5001 node server/index.js",
    "client": "CALC_API_PORT=5001 npx vite --config client/vite.config.js",
    "build:client": "npx vite build --config client/vite.config.js",
    "build": "npm run build:client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.4"
  }
}
